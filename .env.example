# ---- Application ----
APP_NAME="Analytics Search Backend"
LOG_LEVEL=INFO

# ---- Database ----
# Async SQLAlchemy URL. For docker-compose this points at the "db" service.
# For local runs against a local Postgres, use localhost.
DATABASE_URL=postgresql+asyncpg://analytics:analytics@localhost:5432/analytics

# ---- Embeddings ----
# EMBEDDING_MODE: mock | local | openai
#   mock  -> deterministic hash-based vectors (no downloads, best for CI/review)
#   local -> sentence-transformers all-MiniLM-L6-v2 (requires: uv sync --extra local)
#   openai-> placeholder interface (not wired to a live key in this assignment)
EMBEDDING_MODE=mock
EMBEDDING_DIM=384
LOCAL_MODEL_NAME=all-MiniLM-L6-v2

# ---- Vector store (ChromaDB, persistent local) ----
CHROMA_DIR=./chroma_data
CHROMA_COLLECTION=events

# ---- Analytics ----
DEFAULT_TOP_USERS=10
